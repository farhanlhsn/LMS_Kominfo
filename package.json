{
  "name": "lms-platform",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev --parallel",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "lint": "turbo lint",
    "db:generate": "pnpm --filter @lms/db prisma:generate",
    "db:migrate": "pnpm --filter @lms/db prisma:migrate",
    "db:deploy": "pnpm --filter @lms/db prisma:deploy",
    "db:seed": "pnpm --filter @lms/db db:seed",
    "e2e": "pnpm db:seed && playwright test",
    "e2e:api": "pnpm db:seed && playwright test --project=api",
    "e2e:ui": "pnpm db:seed && playwright test --project=chromium",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\""
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "prettier": "^3.6.2",
    "prisma": "^6.10.1",
    "tsx": "^4.20.3",
    "turbo": "^2.5.8",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
