{
  "name": "lms-platform",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev --parallel",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:unit": "turbo test",
    "test:coverage": "turbo test:coverage",
    "test:integration": "node scripts/test-integration.mjs",
    "verify": "pnpm lint && pnpm typecheck && pnpm build && pnpm test:unit",
    "test:full": "pnpm test:unit && pnpm test:integration && pnpm test:coverage && pnpm e2e",
    "lint": "turbo lint",
    "lint:eslint": "eslint \"apps/**/*.{ts,tsx}\" \"packages/**/*.{ts,tsx}\"",
    "db:generate": "pnpm --filter @lms/db prisma:generate",
    "db:migrate": "pnpm --filter @lms/db prisma:migrate",
    "db:deploy": "pnpm --filter @lms/db prisma:deploy",
    "db:seed": "pnpm --filter @lms/db db:seed",
    "e2e": "pnpm db:seed && playwright test",
    "e2e:api": "pnpm db:seed && playwright test --project=api",
    "e2e:idor": "pnpm db:seed && playwright test e2e/api/09-idor-regression.spec.ts --project=api",
    "e2e:ui": "pnpm db:seed && playwright test --project=chromium",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\""
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "^16.2.10",
    "@playwright/test": "^1.61.1",
    "eslint": "^10.7.0",
    "eslint-plugin-no-secrets": "^2.3.3",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-security": "^4.0.1",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "prisma": "^6.10.1",
    "tsx": "^4.20.3",
    "turbo": "^2.5.8",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^3.2.4"
  }
}
