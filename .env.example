NODE_ENV=development

# API
API_PORT=4000
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=30

# Database
POSTGRES_PORT=55432
DATABASE_URL=postgresql://lms:lms_password@localhost:55432/lms?schema=public

# Cache and queue
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# S3-compatible storage
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_ENDPOINT=http://localhost:9000
S3_REGION=local
S3_BUCKET=lms-local
S3_ACCESS_KEY_ID=minio
S3_SECRET_ACCESS_KEY=minio_password

# Seed
SEED_SUPER_ADMIN_EMAIL=super.admin@example.com
SEED_SUPER_ADMIN_PASSWORD=ChangeMe123!
SEED_DEMO_ORG_NAME=Demo Learning Organization
SEED_DEMO_ORG_SLUG=demo-learning
