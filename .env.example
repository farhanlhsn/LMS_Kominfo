NODE_ENV=development

# API
API_PORT=4000
NEXT_PUBLIC_API_URL=/api/v1
PUBLIC_APP_URL=http://localhost:3000
# Show demo quick-login + seed password on /login.
# Production Docker web image forces false at build (see docker/web.Dockerfile).
# Set "false" for any tenant-facing build; Playwright/local demo may use "true".
# Defaults to on when NODE_ENV is not production if unset.
NEXT_PUBLIC_DEMO_LOGIN=true
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
ENTERPRISE_SECRET_KEY=change-me-enterprise-secret
PLUGIN_SECRET_ENCRYPTION_KEY=change-me-plugin-secret
FILE_URL_SIGNING_SECRET=change-me-file-url-secret
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=30
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Database
POSTGRES_PORT=55432
DATABASE_URL=postgresql://lms:lms_password@localhost:55432/lms?schema=public

# Cache and queue
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# Code runner sandbox (ADR-009)
# auto = Judge0 when JUDGE0_BASE_URL set, else mock (dev only)
# mock = host child_process (never use in production)
# judge0 = remote Judge0-compatible API
CODE_RUNNER_PROVIDER=auto
LMS_CORE_VERSION=1.0.0
# Local Judge0 CE (optional):
#   docker compose --profile code-runner up -d
#   JUDGE0_BASE_URL=http://localhost:2358
#   CODE_RUNNER_PROVIDER=judge0
# API-in-Docker should use: http://judge0-server:2358
# JUDGE0_BASE_URL=http://localhost:2358
# JUDGE0_API_KEY=
# JUDGE0_PORT=2358

# Optional: protect /health/metrics from non-private networks
# METRICS_TOKEN=change-me-metrics-token

# S3-compatible storage
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_ENDPOINT=http://localhost:9000
S3_REGION=local
S3_BUCKET=lms-local
S3_ACCESS_KEY_ID=minio
S3_SECRET_ACCESS_KEY=minio_password

# -----------------------------------------------------------------------------
# AI / RAG / Tutor
# -----------------------------------------------------------------------------

AI_ENABLED=false # (default: false)

# Supported values: mock, openai, openai_compatible, gemini_openai_compatible
AI_CHAT_PROVIDER=mock # (default: mock)

# Supported values: mock, openai, openai_compatible, gemini_openai_compatible, local
AI_EMBEDDING_PROVIDER=mock # (default: mock)

# Supported values: rules_first, rules_then_local
AI_ROUTER_MODE=rules_then_local # (default: rules_then_local)

# Supported values: STRICT_COURSE_ONLY, COURSE_FIRST_WITH_DOMAIN_FALLBACK,
# GENERAL_EDUCATIONAL_ALLOWED, DISABLED
AI_ANSWER_MODE=COURSE_FIRST_WITH_DOMAIN_FALLBACK # (default: COURSE_FIRST_WITH_DOMAIN_FALLBACK)

AI_ALLOW_GENERAL_EDUCATIONAL=true # (default: true)
AI_ALLOW_OFF_TOPIC=false # (default: false)
AI_REQUEST_TIMEOUT_MS=60000 # (default: 60000)
AI_STREAMING_ENABLED=true # (default: true)
AI_MAX_OUTPUT_TOKENS=900 # (default: 900)
AI_DEFAULT_TEMPERATURE=0.2 # (default: 0.2)

# RAG retrieval budget
AI_RAG_TOP_K=5 # (default: 5)
AI_RAG_MIN_SCORE=0.2 # (default: 0.2)
AI_MAX_CONTEXT_TOKENS=3500 # (default: 3500)

# Answer cache
AI_ENABLE_ANSWER_CACHE=true # (default: true)
AI_ANSWER_CACHE_TTL_SECONDS=86400 # (default: 86400)

# Follow-up question suggestions
AI_ENABLE_FOLLOWUP_SUGGESTIONS=true # (default: true)
AI_FOLLOWUP_SUGGESTION_COUNT=3 # (default: 3)

# Canonical question normalization
AI_CANONICALIZATION_ENABLED=true # (default: true)
AI_CANONICALIZATION_USE_EXTERNAL_MODEL=false # (default: false)
AI_CANONICAL_SIMILARITY_THRESHOLD=0.86 # (default: 0.86)

# Local/offline classifier
AI_LOCAL_CLASSIFIER_ENABLED=true # (default: true)
AI_LOCAL_CLASSIFIER_PROVIDER=rules_and_embedding # (default: rules_and_embedding)

# Local/offline embedding model for classifier/canonical matching
# Default recommendation: intfloat/multilingual-e5-small
AI_LOCAL_EMBEDDING_PROVIDER=transformers_js # (default: transformers_js)
AI_LOCAL_EMBEDDING_MODEL=intfloat/multilingual-e5-small # (default: intfloat/multilingual-e5-small)
AI_LOCAL_EMBEDDING_MODEL_REVISION= # (default: empty)
AI_LOCAL_EMBEDDING_VERSION= # (default: empty)
AI_LOCAL_EMBEDDING_DIMENSIONS=384 # (default: 384)
AI_LOCAL_EMBEDDING_QUERY_PREFIX=query: # (default: "query:")
AI_LOCAL_EMBEDDING_DOCUMENT_PREFIX=passage: # (default: "passage:")
AI_LOCAL_EMBEDDING_NORMALIZE=true # (default: true)

# Local classifier thresholds
AI_DOMAIN_SIMILARITY_THRESHOLD=0.78 # (default: 0.78)
AI_OFF_TOPIC_SIMILARITY_THRESHOLD=0.80 # (default: 0.80)
AI_LOCAL_CLASSIFIER_TIMEOUT_MS=10000 # (default: 10000)

# Official OpenAI (required only when selected while AI is enabled)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1 # (default: https://api.openai.com/v1)
OPENAI_CHAT_MODEL=
OPENAI_EMBEDDING_MODEL=
OPENAI_ORG_ID=

# Generic OpenAI-compatible provider
# Examples: OpenRouter, Groq, Together AI, LM Studio, Ollama OpenAI-compatible endpoint
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_CHAT_MODEL=
OPENAI_COMPATIBLE_EMBEDDING_MODEL=
OPENAI_COMPATIBLE_ORG_ID=

# Gemini through OpenAI-compatible API
GEMINI_API_KEY=
GEMINI_OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/ # (default: https://generativelanguage.googleapis.com/v1beta/openai/)
GEMINI_CHAT_MODEL=gemini-2.5-flash # (default: gemini-2.5-flash)
GEMINI_EMBEDDING_MODEL=

# AI usage / safety
AI_USAGE_LOGGING_ENABLED=true # (default: true)
AI_LOG_PROMPTS=false # (default: false)
AI_RATE_LIMIT_ENABLED=true # (default: true)
AI_RATE_LIMIT_PER_USER_PER_MINUTE=10 # (default: 10)
AI_RATE_LIMIT_PER_ORG_PER_MINUTE=100 # (default: 100)

# Seed
SEED_SUPER_ADMIN_EMAIL=super.admin@example.com
SEED_SUPER_ADMIN_PASSWORD=ChangeMe123!
SEED_DEMO_ORG_NAME=Demo Learning Organization
SEED_DEMO_ORG_SLUG=demo-learning

# Web Push (VAPID)
PUSH_VAPID_SUBJECT=mailto:admin@example.com
PUSH_VAPID_PUBLIC_KEY=
PUSH_VAPID_PRIVATE_KEY=

# -----------------------------------------------------------------------------
# Email / SMTP
# -----------------------------------------------------------------------------
# Set these to enable email delivery (password reset, invitations, welcome emails)
# Supports any SMTP provider: Gmail, SendGrid, Mailgun, Resend, self-hosted, etc.
#
# Gmail example:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=youraddress@gmail.com
#   SMTP_PASS=your-app-password   (use App Password if 2FA is on)
#
# SendGrid example:
#   SMTP_HOST=smtp.sendgrid.net
#   SMTP_PORT=587
#   SMTP_USER=apikey
#   SMTP_PASS=SG.xxxxxxxxxxxx
#
# Resend example:
#   SMTP_HOST=smtp.resend.com
#   SMTP_PORT=587
#   SMTP_USER=resend
#   SMTP_PASS=re_xxxxxxxxxxxx
#
# If left empty, email delivery is disabled but the app still works normally.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=LMS Platform <noreply@example.com>

# Public URL used in email links (password reset, invitation)
PUBLIC_APP_URL=http://localhost:3000
