# Application
NODE_ENV=development
PORT=4000
APP_URL=http://localhost:4000
WEB_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lms_kominfo?schema=public

# Redis
REDIS_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Authentication
JWT_ACCESS_SECRET=your_super_secret_access_key_here
JWT_REFRESH_SECRET=your_super_secret_refresh_key_here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# Storage (MINIO / LOCAL)
STORAGE_PROVIDER=LOCAL
LOCAL_STORAGE_PATH=./uploads
# MinIO Config (Jika STORAGE_PROVIDER=MINIO)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=lms-materials
MINIO_USE_SSL=false

# AI (OpenAI)
OPENAI_API_KEY=sk-your-openai-api-key

# Rate Limiting
RATE_LIMIT_AUTHENTICATED_PER_MIN=300
RATE_LIMIT_AUTH_PER_MIN=10
RATE_LIMIT_AI_PER_MIN=15
RATE_LIMIT_SEARCH_PER_MIN=60
