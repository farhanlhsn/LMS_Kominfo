{
  "name": "@lms/db",
  "version": "0.0.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "node --max-old-space-size=4096 ../../node_modules/typescript/bin/tsc -p tsconfig.json",
    "typecheck": "node --max-old-space-size=4096 ../../node_modules/typescript/bin/tsc -p tsconfig.json --noEmit && node --max-old-space-size=4096 ../../node_modules/typescript/bin/tsc -p tsconfig.prisma.json --noEmit",
    "lint": "pnpm typecheck",
    "test": "vitest run --passWithNoTests",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:status": "prisma migrate status",
    "db:seed": "prisma db seed"
  },
  "dependencies": {
    "@lms/shared": "workspace:*",
    "@prisma/client": "^7.9.0",
    "bcryptjs": "^3.0.2"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "dotenv": "^17.4.2",
    "prisma": "^7.9.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
