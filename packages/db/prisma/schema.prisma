  aiDocumentChunks           AiDocumentChunk[]
  aiCanonicalQuestions       AiCanonicalQuestion[]
  aiClassificationPrototypes AiClassificationPrototype[]
  aiDocuments                AiDocument[]
  aiAnswerCaches             AiAnswerCache[]
  aiConversations            AiConversation[]
  aiUsageLogs                AiUsageLog[]
  aiGeneratedItems           AiGeneratedItem[]
  discussionThreads          DiscussionThread[]
  discussionReplies          DiscussionReply[]
  liveClasses                LiveClass[]
  notifications              Notification[]
  notificationPreferences    NotificationPreference[]
  discussionReports          DiscussionReport[]
  calendarEvents             CalendarEvent[]
