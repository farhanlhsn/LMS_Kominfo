model OrganizationMember {
  id             String                   @id @default(cuid())
  organizationId String
  userId         String
  status         OrganizationMemberStatus @default(ACTIVE)
  invitedAt      DateTime?
  joinedAt       DateTime?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  organization   Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  memberRoles    MemberRole[]

  @@unique([organizationId, userId])
  @@index([organizationId, status])
  @@index([userId])
}

model Role {
  id                     String           @id @default(cuid())
  organizationId         String?
  key                    String
  name                   String
  description            String?
  isSystem               Boolean          @default(false)
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
  organization           Organization?    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  rolePermissions        RolePermission[]
  memberRoles            MemberRole[]
  defaultForSsoProviders SsoProvider[]    @relation("SsoProviderDefaultRole")

  @@unique([organizationId, key])
  @@index([key])
  @@index([organizationId])
}

model Permission {
  id              String           @id @default(cuid())
  key             String           @unique
  description     String?
  createdAt       DateTime         @default(now())
  rolePermissions RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  createdAt    DateTime   @default(now())
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
}

model MemberRole {
  memberId  String
  roleId    String
  createdAt DateTime           @default(now())
  member    OrganizationMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  role      Role               @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([memberId, roleId])
  @@index([roleId])
}

model UserSession {
  id                   String        @id @default(cuid())
  userId               String
  activeOrganizationId String?
  tokenHash            String
  ipAddress            String?
  userAgent            String?
  expiresAt            DateTime
  lastUsedAt           DateTime?
  revokedAt            DateTime?
  revokedReason        String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  user                 User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  activeOrganization   Organization? @relation(fields: [activeOrganizationId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([activeOrganizationId])
  @@index([expiresAt])
}

model SsoProvider {
  id                     String               @id @default(cuid())
  organizationId         String
  type                   SsoProviderType
  name                   String
  issuer                 String
  entityId               String?
  clientId               String?
  clientSecretEncrypted  String?
  metadataUrl            String?
  metadataXml            String?
  authorizationUrl       String?
  tokenUrl               String?
  userInfoUrl            String?
  callbackUrl            String
  enabled                Boolean              @default(false)
  jitProvisioningEnabled Boolean              @default(false)
  inviteOnly             Boolean              @default(true)
  defaultRoleId          String?
  groupRoleMappings      Json?
  config                 Json                 @default("{}")
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  organization           Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  defaultRole            Role?                @relation("SsoProviderDefaultRole", fields: [defaultRoleId], references: [id], onDelete: SetNull)
  identities             UserIdentity[]
  domains                OrganizationDomain[]

  @@index([organizationId])
  @@index([organizationId, enabled])
}

model UserIdentity {
  id                    String               @id @default(cuid())
  userId                String
  organizationId        String?
  providerType          IdentityProviderType
  ssoProviderId         String?
  providerSubject       String
  providerEmail         String
  providerEmailVerified Boolean              @default(false)
  rawProfile            Json                 @default("{}")
  lastLoginAt           DateTime?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  user                  User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  ssoProvider           SsoProvider?         @relation(fields: [ssoProviderId], references: [id], onDelete: SetNull)

  @@unique([providerType, organizationId, providerSubject])
  @@unique([ssoProviderId, providerSubject])
  @@index([userId])
  @@index([organizationId])
}

model OrganizationDomain {
  id                 String                   @id @default(cuid())
  organizationId     String
  domain             String
  verificationStatus DomainVerificationStatus @default(PENDING)
  verifiedAt         DateTime?
  ssoProviderId      String?
  enforceSso         Boolean                  @default(false)
  autoJoinEnabled    Boolean                  @default(false)
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  organization       Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ssoProvider        SsoProvider?             @relation(fields: [ssoProviderId], references: [id], onDelete: SetNull)

  @@unique([organizationId, domain])
  @@index([domain])
  @@index([organizationId, verificationStatus])
}

model OrganizationLoginPolicy {
  id                           String       @id @default(cuid())
  organizationId               String       @unique
  allowPasswordLogin           Boolean      @default(true)
  allowSocialLogin             Boolean      @default(false)
  allowSsoLogin                Boolean      @default(false)
  requireSsoForVerifiedDomains Boolean      @default(false)
  jitProvisioningEnabled       Boolean      @default(false)
  inviteOnly                   Boolean      @default(false)
  mfaRequired                  Boolean      @default(false)
  sessionTtlMinutes            Int          @default(43200)
  createdAt                    DateTime     @default(now())
  updatedAt                    DateTime     @updatedAt
  organization                 Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model CourseCategory {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  slug           String
  description    String?
  orderIndex     Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  courses        Course[]

  @@unique([organizationId, slug])
  @@index([organizationId, orderIndex])
}

model Course {
  id                        String                 @id @default(cuid())
  organizationId            String
  categoryId                String?
  title                     String
  slug                      String
  subtitle                  String?
  description               String?
  thumbnailUrl              String?
  level                     CourseLevel            @default(ALL_LEVELS)
  language                  String                 @default("en")
  durationMinutes           Int                    @default(0)
  status                    CourseStatus           @default(DRAFT)
  visibility                CourseVisibility       @default(ORGANIZATION_ONLY)
  learningObjectives        Json                   @default("[]")
  requirements              Json                   @default("[]")
  targetAudience            Json                   @default("[]")
  tags                      Json                   @default("[]")
  metadata                  Json                   @default("{}")
  autoCertificate           Boolean                @default(false)
  isPaid                    Boolean                @default(false)
  price                     Int?
  currency                  String                 @default("IDR")
