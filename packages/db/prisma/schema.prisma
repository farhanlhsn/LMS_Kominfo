  dueAt            DateTime?
  rubricId         String?
  anonymize        Boolean           @default(true)
  allowSelfReview  Boolean           @default(false)
  status           String            @default("DRAFT")
  metadata         Json              @default("{}")
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignment       Assignment        @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  rubric           Rubric?           @relation(fields: [rubricId], references: [id], onDelete: SetNull)
  matches          PeerReviewMatch[]

  @@index([organizationId, status])
}

model PeerReviewMatch {
  id             String               @id @default(cuid())
  organizationId String
  configId       String
  submissionId   String
  reviewerUserId String
  status         PeerReviewStatus     @default(PENDING)
  dueAt          DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  config         PeerReviewConfig     @relation(fields: [configId], references: [id], onDelete: Cascade)
  submission     AssignmentSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  reviewer       User                 @relation("PeerReviewReviewer", fields: [reviewerUserId], references: [id], onDelete: Cascade)
  review         PeerReview?

  @@unique([configId, submissionId, reviewerUserId])
  @@index([organizationId, reviewerUserId])
  @@index([organizationId, status])
}

model PeerReview {
  id             String                  @id @default(cuid())
  organizationId String
  matchId        String                  @unique
  authorId       String?
  overallScore   Float?
  feedback       String?
  submittedAt    DateTime?
