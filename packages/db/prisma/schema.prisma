  id                         String                        @id @default(cuid())
  name                       String
  slug                       String                        @unique
  timezone                   String                        @default("UTC")
  status                     OrganizationStatus            @default(ACTIVE)
  logoUrl                    String?
  faviconUrl                 String?
  primaryColor               String?
  secondaryColor             String?
  accentColor                String?
  borderRadius               String?
  createdAt                  DateTime                      @default(now())
  updatedAt                  DateTime                      @updatedAt
  members                    OrganizationMember[]
  roles                      Role[]
  auditLogs                  AuditLog[]
  sessions                   UserSession[]
  ssoProviders               SsoProvider[]
  domains                    OrganizationDomain[]
  loginPolicy                OrganizationLoginPolicy?
  courseCategories           CourseCategory[]
  courses                    Course[]
  courseInstructors          CourseInstructor[]
  enrollments                Enrollment[]
  activityProgress           ActivityProgress[]
  learningEvents             LearningEvent[]
  files                      File[]
  folders                    Folder[]
  contentItems               ContentLibraryItem[]
  organizationPlugins        OrganizationPlugin[]
  pluginLogs                 PluginExecutionLog[]
  workspacePreferences       LearningWorkspacePreference[]
  lessonWorkspaceStates      LessonWorkspaceState[]
  learnerNotes               LearnerNote[]
  learnerBookmarks           LearnerBookmark[]
