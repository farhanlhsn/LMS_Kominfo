model SearchQuery {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  query          String
  types          Json     @default("[]")
  resultsCount   Int      @default(0)
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation("SearchQueryUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([organizationId, userId])
  @@index([organizationId, query])
}

model HelpCategory {
  id             String   @id @default(cuid())
  organizationId String
  key            String
  title          String
  description    String?
  icon           String?
  orderIndex     Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  articles     HelpArticle[]

  @@unique([organizationId, key])
  @@index([organizationId, orderIndex])
}

model HelpArticle {
  id             String    @id @default(cuid())
  organizationId String
  categoryId     String
  slug           String
  title          String
  body           String
  excerpt        String?
  status         String    @default("DRAFT")
  tags           Json      @default("[]")
  viewCount      Int       @default(0)
  publishedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  category     HelpCategory      @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  views        HelpArticleView[]

  @@unique([organizationId, slug])
  @@index([organizationId, categoryId])
  @@index([organizationId, status])
}

model HelpArticleView {
  id             String   @id @default(cuid())
  organizationId String
  articleId      String
  userId         String?
  viewedAt       DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  article      HelpArticle  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  user         User?        @relation("HelpArticleViewUser", fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId, articleId])
  @@index([organizationId, viewedAt])
}

model SupportTicket {
  id             String    @id @default(cuid())
  organizationId String
  userId         String
  subject        String
  body           String
  category       String    @default("general")
  priority       String    @default("NORMAL")
  status         String    @default("OPEN")
  assignedToId   String?
  metadata       Json      @default("{}")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  closedAt       DateTime?

  organization Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User                 @relation("SupportTicketRequester", fields: [userId], references: [id], onDelete: Cascade)
  assignedTo   User?                @relation("SupportTicketAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  replies      SupportTicketReply[]

  @@index([organizationId, userId])
  @@index([organizationId, status])
  @@index([organizationId, createdAt])
}

model SupportTicketReply {
  id             String   @id @default(cuid())
  organizationId String
  ticketId       String
  authorId       String
  body           String
  isInternal     Boolean  @default(false)
  createdAt      DateTime @default(now())

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ticket       SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author       User          @relation("SupportTicketReplyAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([organizationId, ticketId])
}

model UserLocalePreference {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  locale         String   @default("en")
  timezone       String   @default("UTC")
  fallbackChain  Json     @default("[]")
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation("UserLocalePreferenceUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
}

model OrgLocalePreference {
  id               String   @id @default(cuid())
  organizationId   String   @unique
  defaultLocale    String   @default("en")
  supportedLocales Json     @default("[\"en\"]")
  fallbackChain    Json     @default("[\"en\"]")
  metadata         Json     @default("{}")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model TranscriptNote {
  id               String   @id @default(cuid())
  organizationId   String
  userId           String
  lessonId         String
  activityId       String?
  timestampSeconds Float    @default(0)
  content          String
  color            String   @default("yellow")
  tags             Json     @default("[]")
  metadata         Json     @default("{}")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation("TranscriptNoteUser", fields: [userId], references: [id], onDelete: Cascade)
  lesson       Lesson       @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  activity     Activity?    @relation(fields: [activityId], references: [id], onDelete: SetNull)
  context      NoteContext?

  @@index([organizationId, userId])
  @@index([organizationId, lessonId])
  @@index([organizationId, activityId])
}

model NoteContext {
  id               String   @id @default(cuid())
  organizationId   String
  noteId           String   @unique
  aiContextSummary String
  relatedNotes     Json     @default("[]")
  providerKey      String   @default("mock")
  metadata         Json     @default("{}")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  note         TranscriptNote @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
}

model NotesExport {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  lessonId       String?
  format         String   @default("markdown")
  status         String   @default("COMPLETED")
  markdown       String   @default("")
  count          Int      @default(0)
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now())

  organization Organization @relation("NotesExportOrg", fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation("NotesExportUser", fields: [userId], references: [id], onDelete: Cascade)
  lesson       Lesson?      @relation("NotesExportLesson", fields: [lessonId], references: [id], onDelete: SetNull)

  @@index([organizationId, userId])
  @@index([organizationId, lessonId])
}

// Phase 23: Timezone & cohort scheduling
enum CohortStatus {
  PLANNED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum CohortMemberStatus {
  ACTIVE
  WITHDRAWN
  COMPLETED
}

model Cohort {
  id             String           @id @default(cuid())
  organizationId String
  name           String
  courseId       String
  startAt        DateTime
  endAt          DateTime
  timezone       String           @default("UTC")
  maxSeats       Int              @default(0)
  status         CohortStatus     @default(PLANNED)
  metadata       Json             @default("{}")
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  course         Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  members        CohortMember[]
  schedule       CohortSchedule[]

  @@index([organizationId, courseId])
  @@index([organizationId, status])
  @@index([organizationId, startAt])
}

model CohortMember {
  id             String             @id @default(cuid())
  organizationId String
  cohortId       String
  userId         String
  status         CohortMemberStatus @default(ACTIVE)
  joinedAt       DateTime           @default(now())
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  cohort         Cohort             @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  user           User               @relation("CohortMemberUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([cohortId, userId])
  @@index([organizationId, userId])
  @@index([organizationId, status])
}

model CohortSchedule {
  id             String       @id @default(cuid())
  organizationId String
  cohortId       String
  weekday        Int
  startTime      String
  endTime        String
  lessonId       String?
  meetingUrl     String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  cohort         Cohort       @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  lesson         Lesson?      @relation(fields: [lessonId], references: [id], onDelete: SetNull)

  @@index([organizationId, cohortId])
  @@index([organizationId, weekday])
}

model UserTimezonePreference {
  id         String   @id @default(cuid())
  userId     String   @unique
  timezone   String   @default("UTC")
  autoDetect Boolean  @default(false)
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())
  user       User     @relation("UserTimezonePreferenceUser", fields: [userId], references: [id], onDelete: Cascade)
}

// Phase 28: Proctoring
enum ProctoringSessionStatus {
  ACTIVE
  COMPLETED
  FLAGGED
  REVIEWED
}

enum ProctoringEventType {
  TAB_SWITCH
  FULLSCREEN_EXIT
  COPY_PASTE
  LOOKING_AWAY
  NO_FACE
  MULTIPLE_FACES
  PHONE_DETECTED
  NOISE_DETECTED
}

enum ProctoringSeverity {
  LOW
  MEDIUM
  HIGH
}

enum ProctoringFlagStatus {
  OPEN
  DISMISSED
  UPHELD
}

model ProctoringSession {
  id             String                  @id @default(cuid())
  organizationId String
  attemptId      String
  attemptType    String                  @default("quiz")
  userId         String
  startedAt      DateTime                @default(now())
  endedAt        DateTime?
  status         ProctoringSessionStatus @default(ACTIVE)
  integrityScore Float?
  metadata       Json                    @default("{}")
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  organization   Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User                    @relation("ProctoringSessionUser", fields: [userId], references: [id], onDelete: Cascade)
  events         ProctoringEvent[]
  flags          ProctoringFlag[]

  @@unique([organizationId, attemptId, attemptType])
  @@index([organizationId, userId])
  @@index([organizationId, status])
}

model ProctoringEvent {
  id             String              @id @default(cuid())
  organizationId String
  sessionId      String
  type           ProctoringEventType
  severity       ProctoringSeverity  @default(LOW)
  metadata       Json                @default("{}")
  occurredAt     DateTime            @default(now())
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  session        ProctoringSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  flags          ProctoringFlag[]

  @@index([organizationId, sessionId])
  @@index([organizationId, type])
}

model ProctoringFlag {
  id             String               @id @default(cuid())
  organizationId String
  sessionId      String
  eventId        String?
  status         ProctoringFlagStatus @default(OPEN)
  notes          String?
  reviewedBy     String?
  reviewedAt     DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  session        ProctoringSession    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  event          ProctoringEvent?     @relation(fields: [eventId], references: [id], onDelete: SetNull)
  reviewer       User?                @relation("ProctoringFlagReviewer", fields: [reviewedBy], references: [id], onDelete: SetNull)

  @@index([organizationId, status])
  @@index([organizationId, sessionId])
}

// Phase 29: Revenue share & payout
enum RevenueShareScope {
  PLATFORM
  INSTRUCTOR
  COURSE
}

enum PayoutPeriodStatus {
  OPEN
  LOCKED
  PAID
}

enum PayoutBeneficiaryType {
  INSTRUCTOR
  ORG
  PLATFORM
}

enum PayoutStatus {
  PENDING
  APPROVED
  PAID
  FAILED
}

enum PayoutMethodType {
  BANK
  PAYPAL
  STRIPE
}

model RevenueShareRule {
  id             String            @id @default(cuid())
  organizationId String
  scope          RevenueShareScope @default(INSTRUCTOR)
  targetId       String?
  percent        Float             @default(0)
  active         Boolean           @default(true)
  metadata       Json              @default("{}")
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, scope, active])
}

model PayoutPeriod {
  id             String             @id @default(cuid())
  organizationId String
  periodStart    DateTime
  periodEnd      DateTime
  status         PayoutPeriodStatus @default(OPEN)
  totalAmount    Int                @default(0)
  currency       String             @default("USD")
  lockedAt       DateTime?
  paidAt         DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  payouts        Payout[]

  @@index([organizationId, status])
  @@index([organizationId, periodStart, periodEnd])
}

model Payout {
  id              String                @id @default(cuid())
  organizationId  String
  periodId        String
  beneficiaryType PayoutBeneficiaryType
  beneficiaryId   String
  grossAmount     Int                   @default(0)
  feeAmount       Int                   @default(0)
  netAmount       Int                   @default(0)
  currency        String                @default("USD")
  status          PayoutStatus          @default(PENDING)
  reference       String?
  paidAt          DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  organization    Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  period          PayoutPeriod          @relation(fields: [periodId], references: [id], onDelete: Cascade)

  @@index([organizationId, periodId])
  @@index([organizationId, status])
  @@index([organizationId, beneficiaryType, beneficiaryId])
}

model PayoutMethod {
  id              String                @id @default(cuid())
  organizationId  String
  beneficiaryType PayoutBeneficiaryType
  beneficiaryId   String
  type            PayoutMethodType
  details         Json                  @default("{}")
  verifiedAt      DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  organization    Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, beneficiaryType, beneficiaryId])
}

// Phase 30: Multi-currency & tax
enum TaxRuleType {
  VAT
  GST
  SALES_TAX
}

model TaxRegion {
  code       String    @id
  name       String
  currency   String
  taxPercent Float     @default(0)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  rules      TaxRule[]
}

model TaxRule {
  id             String       @id @default(cuid())
  organizationId String
  regionCode     String
  rate           Float        @default(0)
  type           TaxRuleType  @default(VAT)
  inclusive      Boolean      @default(false)
  active         Boolean      @default(true)
  metadata       Json         @default("{}")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  region         TaxRegion    @relation(fields: [regionCode], references: [code], onDelete: Cascade)

  @@index([organizationId, regionCode, active])
}

model TaxCalculation {
  id             String       @id @default(cuid())
  organizationId String
  orderId        String
  regionCode     String
  subtotal       Int          @default(0)
  taxAmount      Int          @default(0)
  total          Int          @default(0)
  currency       String       @default("USD")
  breakdown      Json         @default("{}")
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  order          Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([organizationId, orderId])
  @@index([organizationId, regionCode])
}
