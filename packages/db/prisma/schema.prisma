// Phase 25: Bulk Operations
// ===========================================================================

enum BulkJobType {
  IMPORT
  EXPORT
  ARCHIVE
  UNARCHIVE
  ENROLL
  UNENROLL
  TAG
  UNTAG
}

enum BulkJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
  PARTIAL
}

enum BulkJobItemStatus {
  PENDING
  PROCESSED
  FAILED
  SKIPPED
}

model BulkJob {
  id             String        @id @default(cuid())
  organizationId String
  type           BulkJobType
  status         BulkJobStatus @default(PENDING)
  input          Json          @default("{}")
  result         Json          @default("{}")
  progressTotal  Int           @default(0)
  progressDone   Int           @default(0)
  progressFailed Int           @default(0)
  errorMessage   String?
  startedAt      DateTime?
  completedAt    DateTime?
  createdById    String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User          @relation(fields: [createdById], references: [id], onDelete: Cascade)
  items        BulkJobItem[]

  @@index([organizationId, status])
  @@index([organizationId, type])
  @@index([organizationId, createdAt])
}

model BulkJobItem {
  id             String            @id @default(cuid())
  organizationId String
  jobId          String
  entityType     String
  entityId       String?
  status         BulkJobItemStatus @default(PENDING)
  error          String?
  input          Json              @default("{}")
  processedAt    DateTime?
  createdAt      DateTime          @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  job          BulkJob      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([organizationId, status])
}

// ===========================================================================
// Phase 27: Direct Messaging
// ===========================================================================

enum ConversationType {
  DIRECT
  GROUP
}

enum ConversationMemberRole {
  MEMBER
  ADMIN
}

model Conversation {
  id             String           @id @default(cuid())
  organizationId String
  type           ConversationType @default(DIRECT)
  createdById    String
  name           String?
  metadata       Json             @default("{}")
  lastMessageAt  DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  organization Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User                 @relation("ConversationCreator", fields: [createdById], references: [id], onDelete: Cascade)
  members      ConversationMember[]
  messages     Message[]

  @@index([organizationId, lastMessageAt])
  @@index([organizationId, type])
}

model ConversationMember {
  id             String                 @id @default(cuid())
  organizationId String
  conversationId String
  userId         String
  role           ConversationMemberRole @default(MEMBER)
  joinedAt       DateTime               @default(now())
  lastReadAt     DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([organizationId, userId])
}

model Message {
  id              String    @id @default(cuid())
  organizationId  String
  conversationId  String
  senderId        String
  content         String
  attachments     Json      @default("[]")
  parentMessageId String?
  editedAt        DateTime?
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())

  organization  Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  conversation  Conversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender        User              @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  parentMessage Message?          @relation("MessageThread", fields: [parentMessageId], references: [id], onDelete: SetNull)
  replies       Message[]         @relation("MessageThread")
  reactions     MessageReaction[]
  reads         MessageRead[]

  @@index([organizationId, conversationId, createdAt])
  @@index([organizationId, senderId])
  @@index([parentMessageId])
}

model MessageReaction {
  id             String   @id @default(cuid())
  organizationId String
  messageId      String
  userId         String
  emoji          String
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  message      Message      @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([organizationId, messageId])
}

model MessageRead {
  id             String   @id @default(cuid())
  organizationId String
  messageId      String
  userId         String
  readAt         DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  message      Message      @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([organizationId, userId])
}

model UserBlock {
  id             String   @id @default(cuid())
  organizationId String
  blockerId      String
  blockedId      String
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  blocker      User         @relation("UserBlockBlocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked      User         @relation("UserBlockBlocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([organizationId, blockerId])
}

