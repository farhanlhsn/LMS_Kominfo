// Phase 31: 3D Content Plugin
// ThreeDAsset stores 3D model files (GLB/GLTF/FBX/OBJ) plus thumbnail metadata.

model ThreeDAsset {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  format         String
  sizeBytes      Int      @default(0)
  url            String
  thumbnailUrl   String?
  uploadedBy     String
  createdAt      DateTime @default(now())

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  uploader     User          @relation("ThreeDAssetUploader", fields: [uploadedBy], references: [id], onDelete: Cascade)
  scenes       ThreeDScene[]

  @@index([organizationId, createdAt])
  @@index([organizationId, format])
}

// ThreeDScene defines a scene configuration (lights, camera, env, interactions).

model ThreeDScene {
  id             String   @id @default(cuid())
  organizationId String
  assetId        String
  scene          Json     @default("{}")
  version        Int      @default(1)
  createdAt      DateTime @default(now())

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
