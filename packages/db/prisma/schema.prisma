  updatedAt      DateTime                @updatedAt
  organization   Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  match          PeerReviewMatch         @relation(fields: [matchId], references: [id], onDelete: Cascade)
  author         User?                   @relation("PeerReviewAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  rubricScores   PeerReviewRubricScore[]

  @@index([organizationId, submittedAt])
