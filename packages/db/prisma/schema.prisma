model User {
  id                           String                        @id @default(cuid())
  email                        String                        @unique
  name                         String?
  passwordHash                 String?
  timezone                     String                        @default("UTC")
  status                       UserStatus                    @default(ACTIVE)
  createdAt                    DateTime                      @default(now())
  updatedAt                    DateTime                      @updatedAt
  memberships                  OrganizationMember[]
  sessions                     UserSession[]
  auditLogs                    AuditLog[]
  identities                   UserIdentity[]
  courseInstructors            CourseInstructor[]
  enrollments                  Enrollment[]
  activityProgress             ActivityProgress[]
  learningEvents               LearningEvent[]
  ownedFiles                   File[]                        @relation("FileOwner")
  createdFolders               Folder[]                      @relation("FolderCreator")
  contentItems                 ContentLibraryItem[]          @relation("ContentLibraryCreator")
  installedPlugins             OrganizationPlugin[]          @relation("PluginInstaller")
  pluginLogs                   PluginExecutionLog[]          @relation("PluginLogUser")
  workspacePreferences         LearningWorkspacePreference[]
  lessonWorkspaceStates        LessonWorkspaceState[]
  learnerNotes                 LearnerNote[]
  learnerBookmarks             LearnerBookmark[]
  questionBanks                QuestionBank[]                @relation("QuestionBankOwner")
  questions                    Question[]                    @relation("QuestionCreator")
  quizzes                      Quiz[]                        @relation("QuizCreator")
  quizAttempts                 QuizAttempt[]
  assignments                  Assignment[]                  @relation("AssignmentCreator")
  assignmentSubmissions        AssignmentSubmission[]
  gradedAssignmentSubmissions  AssignmentSubmission[]        @relation("AssignmentSubmissionGrader")
  rubrics                      Rubric[]                      @relation("RubricCreator")
  certificateTemplates         CertificateTemplate[]         @relation("CertificateTemplateCreator")
  certificates                 Certificate[]                 @relation("CertificateLearner")
  revokedCertificates          Certificate[]                 @relation("CertificateRevoker")
  learningGoals                LearningGoal[]
  learningPathEnrollments      LearningPathEnrollment[]
  userSkills                   UserSkill[]
  xpTransactions               XpTransaction[]
  userAchievements             UserAchievement[]
  learnerDailyActivities       LearnerDailyActivity[]
  aiConversations              AiConversation[]
  aiUsageLogs                  AiUsageLog[]
  aiGeneratedItems             AiGeneratedItem[]             @relation("AiGeneratedItemCreator")
  discussionThreads            DiscussionThread[]            @relation("DiscussionThreadAuthor")
  discussionReplies            DiscussionReply[]             @relation("DiscussionReplyAuthor")
  liveClassesCreated           LiveClass[]                   @relation("LiveClassCreator")
  notifications                Notification[]
  notificationPreferences      NotificationPreference[]
  discussionReports            DiscussionReport[]            @relation("DiscussionReportReporter")
  calendarEventsCreated        CalendarEvent[]               @relation("CalendarEventCreator")
  createdCoupons               Coupon[]
  orders                       Order[]
  confirmedPayments            Payment[]
  subscriptions                UserSubscription[]
  createdApiKeys               ApiKey[]
  createdWebhookEndpoints      WebhookEndpoint[]
  authoredCourseReviews        CourseReview[]                @relation("CourseReviewAuthor")
  moderatedCourseReviews       CourseReview[]                @relation("ReviewModerator")
  wishlists                    Wishlist[]
  favoriteInstructorSelections FavoriteInstructor[]          @relation("FavoriteInstructorOwner")
  favoritedByUsers             FavoriteInstructor[]          @relation("FavoriteInstructorUser")
  recentlyViewedCourses        RecentlyViewedCourse[]
  scormAttempts                ScormAttempt[]                @relation("ScormAttemptUser")
  h5pResults                   H5PResult[]                   @relation("H5PResultUser")
  surveyResponses              SurveyResponse[]              @relation("SurveyResponseUser")
  pollVotes                    PollVote[]                    @relation("PollVoteUser")
  courseFeedbackSubmissions    CourseFeedback[]              @relation("CourseFeedbackUser")
  pushSubscriptions            PushSubscription[]            @relation("PushSubscriptionUser")
  assignmentGroupMemberships   AssignmentGroupMember[]
  peerReviewAssignments        PeerReviewMatch[]             @relation("PeerReviewReviewer")
  peerReviewsAuthored          PeerReview[]                  @relation("PeerReviewAuthor")
  submissionAnnotations        SubmissionAnnotation[]        @relation("AnnotationAuthor")
  annotationsResolved          SubmissionAnnotation[]        @relation("AnnotationResolver")
  portfolios                   Portfolio[]                   @relation("PortfolioOwner")
  projectShowcasesCreated      ProjectShowcase[]             @relation("ProjectShowcaseCreator")
  plagiarismChecks             PlagiarismCheck[]             @relation("PlagiarismRequester")
  realtimeEvents               RealtimeEvent[]
  realtimeSubscriptions        RealtimeSubscription[]
  bulkJobsCreated              BulkJob[]
  conversationsCreated         Conversation[]                @relation("ConversationCreator")
  conversationMemberships      ConversationMember[]
  messagesSent                 Message[]                     @relation("MessageSender")
  messageReactions             MessageReaction[]
  messageReads                 MessageRead[]
  usersBlocked                 UserBlock[]                   @relation("UserBlockBlocker")
  usersBlockedBy               UserBlock[]                   @relation("UserBlockBlocked")
  oauthAccounts                OAuthAccount[]                @relation("OAuthAccountOwner")
  mfaFactors                   MfaFactor[]                   @relation("MfaFactorOwner")
  refreshSessions              RefreshSession[]              @relation("RefreshSessionOwner")
  loginAttempts                LoginAttempt[]                @relation("LoginAttemptUser")
  consentRecords               ConsentRecord[]               @relation("ConsentRecordUser")
  dataExportRequests           DataExportRequest[]           @relation("DataExportRequestUser")
  anonymizationRequests        AnonymizationRequest[]        @relation("AnonymizationRequestUser")
  legalAcceptances             LegalAcceptanceLog[]          @relation("LegalAcceptanceLogUser")
  moderationReports            ModerationReport[]            @relation("ModerationReportReporter")
  moderationActionsActored     ModerationAction[]            @relation("ModerationActionActor")
  moderationActionsReviewed    ModerationReport[]            @relation("ModerationReportReviewer")
  contentFlags                 ContentFlag[]                 @relation("ContentFlagFlagger")
  userPanelLayouts             UserPanelLayout[]             @relation("UserPanelLayoutUser")
  cohortMembers                CohortMember[]                @relation("CohortMemberUser")
  userTimezonePreferences      UserTimezonePreference[]      @relation("UserTimezonePreferenceUser")
  proctoringSessions           ProctoringSession[]           @relation("ProctoringSessionUser")
  proctoringFlagsReviewed      ProctoringFlag[]              @relation("ProctoringFlagReviewer")
  searchQueries                SearchQuery[]                 @relation("SearchQueryUser")
  helpArticleViews             HelpArticleView[]             @relation("HelpArticleViewUser")
  supportTickets               SupportTicket[]               @relation("SupportTicketRequester")
  supportTicketsAssigned       SupportTicket[]               @relation("SupportTicketAssignee")
  supportTicketReplies         SupportTicketReply[]          @relation("SupportTicketReplyAuthor")
  userLocalePreferences        UserLocalePreference[]        @relation("UserLocalePreferenceUser")
  transcriptNotes              TranscriptNote[]              @relation("TranscriptNoteUser")
  notesExports                 NotesExport[]                 @relation("NotesExportUser")
  threeDAssets                 ThreeDAsset[]                 @relation("ThreeDAssetUploader")
  codeExecutions               CodeExecution[]               @relation("CodeExecutionUser")
  codeSubmissions              CodeSubmission[]              @relation("CodeSubmissionUser")
  pluginListingsReviewed       PluginListing[]               @relation("PluginListingReviewer")
  pluginReviews                PluginReview[]                @relation("PluginReviewReviewer")
  popoutSessions               PopoutSession[]               @relation("PopoutSessionUser")
  passwordResetTokens          PasswordResetToken[]

  @@index([status])
  @@index([createdAt])
}

