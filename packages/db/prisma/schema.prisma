}

enum MfaFactorType {
  TOTP
  BACKUP_CODE
}

model MfaFactor {
  id             String        @id @default(cuid())
  userId         String
  organizationId String?
  type           MfaFactorType
  secret         String?
  backupCodes    Json          @default("[]")
  verifiedAt     DateTime?
  lastUsedAt     DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  user           User          @relation("MfaFactorOwner", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@index([userId, verifiedAt])
}

model RefreshSession {
  id               String    @id @default(cuid())
  userId           String
  refreshTokenHash String    @unique
  deviceInfo       String?
  ipAddress        String?
  userAgent        String?
  lastUsedAt       DateTime?
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  user             User      @relation("RefreshSessionOwner", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([userId, revokedAt])
}

model LoginAttempt {
  id             String   @id @default(cuid())
  email          String
  organizationId String?
  userId         String?
  success        Boolean
  ipAddress      String?
  userAgent      String?
  captchaToken   String?
  reason         String?
  createdAt      DateTime @default(now())
  user           User?    @relation("LoginAttemptUser", fields: [userId], references: [id], onDelete: SetNull)

  @@index([email, createdAt])
  @@index([organizationId, createdAt])
  @@index([ipAddress, createdAt])
}

// ===========================================================================
// Phase 26: Moderation, Legal, Consent
// ===========================================================================

enum ModerationTargetType {
  CONTENT
  USER
  COMMENT
  COURSE
  DISCUSSION
}

enum ModerationReportStatus {
  OPEN
  IN_REVIEW
  RESOLVED
  DISMISSED
}

model ModerationReport {
  id             String                 @id @default(cuid())
  organizationId String
  reporterId     String
  targetType     ModerationTargetType
  targetId       String
  reason         String
  description    String?
  status         ModerationReportStatus @default(OPEN)
  reviewedById   String?
  reviewedAt     DateTime?
  resolution     String?
  metadata       Json                   @default("{}")
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  organization   Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  reporter       User                   @relation("ModerationReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  reviewedBy     User?                  @relation("ModerationReportReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([organizationId, status])
  @@index([organizationId, targetType, targetId])
  @@index([organizationId, createdAt])
}

enum ModerationActionType {
  WARN
  SUSPEND
  BAN
  REMOVE
  RESTORE
  LOCK
}

model ModerationAction {
  id             String               @id @default(cuid())
  organizationId String
  actorId        String
  targetType     ModerationTargetType
  targetId       String
  actionType     ModerationActionType
  reason         String
  notes          String?
  expiresAt      DateTime?
  createdAt      DateTime             @default(now())
  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actor          User                 @relation("ModerationActionActor", fields: [actorId], references: [id], onDelete: Cascade)

  @@index([organizationId, targetType, targetId])
  @@index([organizationId, actionType])
  @@index([organizationId, createdAt])
}

model ContentFlag {
  id             String               @id @default(cuid())
  organizationId String
  flaggedById    String?
  targetType     ModerationTargetType
  targetId       String
  flagType       String
  autoDetected   Boolean              @default(false)
  confidence     Float?
  reason         String?
  resolvedAt     DateTime?
  createdAt      DateTime             @default(now())
  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  flaggedBy      User?                @relation("ContentFlagFlagger", fields: [flaggedById], references: [id], onDelete: SetNull)

  @@index([organizationId, targetType, targetId])
  @@index([organizationId, flagType])
  @@index([organizationId, autoDetected])
}

model LegalAcceptanceLog {
  id              String            @id @default(cuid())
  userId          String
  organizationId  String
  documentType    LegalDocumentType
  documentVersion String
  acceptedAt      DateTime          @default(now())
  ipAddress       String?
  userAgent       String?
  user            User              @relation("LegalAcceptanceLogUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId, userId])
  @@index([organizationId, documentType])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

