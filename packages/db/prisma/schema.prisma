  action    Json     @default("{}")
  createdAt DateTime @default(now())

  scene ThreeDScene @relation(fields: [sceneId], references: [id], onDelete: Cascade)

  @@index([sceneId])
}

// Phase 32: Code Runner Plugin
// User-generated code NEVER executes in the main API process; a sandbox
// provider handles the actual execution in a separate process.

model CodeExecution {
  id             String    @id @default(cuid())
  organizationId String
  userId         String
  language       String
  code           String
  status         String    @default("PENDING")
  output         String?
  error          String?
  durationMs     Int?
  createdAt      DateTime  @default(now())
  completedAt    DateTime?

  organization Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User                    @relation("CodeExecutionUser", fields: [userId], references: [id], onDelete: Cascade)
  testCases    CodeExecutionTestCase[]

  @@index([organizationId, userId])
  @@index([organizationId, createdAt])
}

model CodeExecutionTestCase {
  id             String  @id @default(cuid())
  executionId    String
  name           String
  input          String  @default("")
  expectedOutput String  @default("")
  actualOutput   String?
  passed         Boolean @default(false)

  execution CodeExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)

  @@index([executionId])
}

model CodeSubmission {
  id             String   @id @default(cuid())
  organizationId String
  assignmentId   String
  userId         String
  language       String
  code           String
  status         String   @default("SUBMITTED")
  score          Float?
  feedback       String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignment   Assignment   @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  user         User         @relation("CodeSubmissionUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId, assignmentId])
  @@index([organizationId, userId])
}

